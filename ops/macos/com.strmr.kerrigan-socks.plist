<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.strmr.kerrigan-socks</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/ssh</string>
		<string>-N</string>
		<string>-D</string>
		<string>127.0.0.1:18080</string>
		<string>-o</string>
		<string>ExitOnForwardFailure=yes</string>
		<string>-o</string>
		<string>ServerAliveInterval=30</string>
		<string>-o</string>
		<string>ServerAliveCountMax=3</string>
		<string>root@100.70.31.6</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/Users/liamhughes/strmr/.logs/kerrigan-socks.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/liamhughes/strmr/.logs/kerrigan-socks.err.log</string>
	<key>WorkingDirectory</key>
	<string>/Users/liamhughes/strmr</string>
</dict>
</plist>
